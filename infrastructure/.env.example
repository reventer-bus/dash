# FOFUS Ubuntu self-host — copy to .env and fill in values
# docker compose --env-file .env up -d

# ── Secrets ─────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_strong_password
SECRET_KEY=run_openssl_rand_hex_32
MINIO_USER=makerai
MINIO_PASSWORD=change_me_minio_password

# ── Shopify (store.fofus.in) ─────────────────────────────────────────────────
# Admin API token: Shopify Admin → Apps → Develop apps → create private app
# Scopes needed: read_orders, write_draft_orders
SHOPIFY_DOMAIN=store.fofus.in
SHOPIFY_ADMIN_TOKEN=shpat_...
# Webhook secret: Shopify Admin → Settings → Notifications → Webhooks → reveal secret
SHOPIFY_WEBHOOK_SECRET=

# ── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OrcaSlicer (if installed on this machine) ────────────────────────────────
ORCA_SLICER_PATH=/opt/OrcaSlicer.AppImage
ORCA_PROFILES_DIR=/opt/orca-profiles
MAKER_AI_DIR=/opt/fofus/data

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=https://api.fofus.in

# ── n8n ──────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://api.fofus.in
