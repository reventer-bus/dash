    {
      "parameters": {
        "jsCode": "const stdout = $input.first().json.stdout;\nconst result = JSON.parse(stdout.trim().split('\\n').pop());\n\nconst body = $('Webhook').first().json.body;\nconst claimed_time = body.claimed_time_seconds;\nconst claimed_weight = body.claimed_weight_grams;\n\nconst time_diff = Math.abs((result.actual_time_seconds - claimed_time) / claimed_time);\nconst weight_diff = Math.abs((result.actual_weight_grams - claimed_weight) / claimed_weight);\n\nreturn [{\n  json: {\n    spec_id: body.spec_id || 'unknown',\n    spec_version: body.spec_version || 'v0',\n    material: body.material || 'unknown',\n    qty: body.qty || 1,\n    machine_class: body.machine_class || 'unknown',\n    actual_time_seconds: result.actual_time_seconds,\n    actual_weight_grams: result.actual_weight_grams,\n    claimed_time_seconds: claimed_time,\n    claimed_weight_grams: claimed_weight,\n    flagged_for_review: time_diff > 0.10 || weight_diff > 0.10\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
