# Clerk authentication (get from clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Auth redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/account
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/upload

# Backend API (FOFUS Maker AI backend)
NEXT_PUBLIC_API_URL=https://fofus.in

# Site URL (used for internal API routes — set to production domain in Vercel)
NEXT_PUBLIC_SITE_URL=https://fofus.in

# Shopify Admin API (server-side only — never expose publicly)
# Get from: store.fofus.in/admin/apps/development → create private app → Admin API access token
SHOPIFY_DOMAIN=store.fofus.in
SHOPIFY_ADMIN_TOKEN=shpat_...
