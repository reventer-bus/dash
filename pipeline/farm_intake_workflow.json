    {
      "parameters": {
        "command": "rm -f ${MAKER_AI_DIR}/spec/sliced_output.3mf && ${ORCA_SLICER_PATH} --slice 0 --export-3mf ${MAKER_AI_DIR}/spec/sliced_output.3mf --load-settings \"${ORCA_PROFILES_DIR}/squashfs-root/resources/profiles/BBL/machine/Bambu Lab A1 0.4 nozzle.json;${ORCA_PROFILES_DIR}/squashfs-root/resources/profiles/BBL/process/0.20mm Standard @BBL A1.json\" --load-filaments \"${ORCA_PROFILES_DIR}/squashfs-root/resources/profiles/BBL/filament/Generic PLA @BBL A1.json\" ${MAKER_AI_DIR}/spec/gridfinity_bin.stl && python3 -c \"import zipfile, re, json, math; z = zipfile.ZipFile('${MAKER_AI_DIR}/spec/sliced_output.3mf'); data = z.read('Metadata/slice_info.config').decode(); prediction = re.search(r'key=\\\"prediction\\\" value=\\\"(\\d+)\\\"', data); length_match = re.search(r'used_m=\\\"([\\d.]+)\\\"', data); length_mm = float(length_match.group(1)) * 1000 if length_match else None; weight_g = round((length_mm * math.pi * (1.75/2)**2 / 1000) * 1.24, 2) if length_mm else None; result = {'actual_time_seconds': int(prediction.group(1)) if prediction else None, 'actual_weight_grams': weight_g}; print(json.dumps(result))\""
      },
