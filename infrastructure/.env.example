# FOFUS Ubuntu self-host — copy to .env and fill in values
# docker compose --env-file .env up -d

# ── Tailscale ────────────────────────────────────────────────────────────────
# 1. Install: curl -fsSL https://tailscale.com/install.sh | sh && tailscale up
# 2. Enable Funnel: tailscale funnel 80
# 3. Your public URL: tailscale funnel status  →  https://<hostname>.ts.net
# 4. Pi agents connect to Ubuntu via Tailscale IP: tailscale ip -4

# ── Secrets ──────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_strong_password
SECRET_KEY=run_openssl_rand_hex_32_here
MINIO_USER=makerai
MINIO_PASSWORD=change_me_minio_password

# ── Shopify (store.fofus.in) ──────────────────────────────────────────────────
# Admin API token: Shopify Admin → Apps → Develop apps → create private app
# Required Admin API scopes: read_orders, write_draft_orders
SHOPIFY_DOMAIN=store.fofus.in
SHOPIFY_ADMIN_TOKEN=shpat_...
# Webhook HMAC secret: Shopify Admin → Settings → Notifications → Webhooks → reveal secret
SHOPIFY_WEBHOOK_SECRET=
# Register this URL in Shopify (Event: Order payment):
#   https://<hostname>.ts.net/api/v1/shopify/webhook

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OrcaSlicer (installed on this Ubuntu machine, not in Docker) ──────────────
ORCA_SLICER_PATH=/opt/OrcaSlicer.AppImage
ORCA_PROFILES_DIR=/opt/orca-profiles
MAKER_AI_DIR=/opt/fofus/data

# ── Frontend (partner dashboard) ─────────────────────────────────────────────
# Use Tailscale Funnel URL so the Vite build can reach the backend from browser
VITE_API_URL=https://<hostname>.ts.net

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://<hostname>.ts.net
